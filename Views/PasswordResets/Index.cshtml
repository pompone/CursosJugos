@model IEnumerable<GestionFormacion.Controllers.PasswordResetViewModel>

@{
    ViewData["Title"] = "Solicitudes de reseteo";
}

<h1>Solicitudes de reseteo de contraseña</h1>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-info">
        @TempData["Mensaje"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-secondary">
        No hay solicitudes de reseteo pendientes.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Legajo / Usuario</th>
                <th>Empleado</th>
                <th>Fecha de solicitud</th>
                <th>Acción</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var solicitud in Model)
            {
                <tr>
                    <td>@solicitud.Legajo</td>
                    <td>@solicitud.NombreCompleto</td>
                    <td>@solicitud.FechaSolicitudReset</td>
                    <td>
                        <form asp-action="Aprobar" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@solicitud.Id" />
                            <button type="submit" class="btn btn-warning btn-sm">
                                Aprobar reseteo
                            </button>
                        </form>

                        <form asp-action="Denegar" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@solicitud.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">
                                Denegar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
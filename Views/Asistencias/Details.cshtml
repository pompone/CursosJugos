@model GestionFormacion.Models.Asistencia

@{
    ViewData["Title"] = "Detalle de asistencia";
}

<h1>Detalle de asistencia</h1>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-light">
        <h4 class="mb-0">Información de la asistencia</h4>
    </div>

    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Empleado</dt>
            <dd class="col-sm-9">
                @Model.Empleado.Apellido, @Model.Empleado.Nombre
            </dd>

            <dt class="col-sm-3">Curso</dt>
            <dd class="col-sm-9">
                @Model.Curso.NombreCurso
            </dd>

            <dt class="col-sm-3">Fecha</dt>
            <dd class="col-sm-9">
                @Model.Fecha.ToString("dd/MM/yyyy HH:mm")
            </dd>

            <dt class="col-sm-3">Asistió</dt>
            <dd class="col-sm-9">
                @if (Model.Asistio)
                {
                    <span class="badge bg-success">Sí</span>
                }
                else
                {
                    <span class="badge bg-danger">No</span>
                }
            </dd>
        </dl>
    </div>

    <div class="card-footer d-flex gap-2">
        <a asp-action="Index" class="btn btn-secondary">
            Volver
        </a>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                Editar
            </a>
        }
    </div>
</div>
@page
@model LoginModel

@{
    ViewData["Title"] = "Inicio de sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inicio de sesión - Gestión de Formación</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="login-body">

    <section class="pantalla-login">
        <div class="login-contenedor">

            <img src="https://static.wixstatic.com/media/a2f3b8_9f3074bd222048c1aea9f9d507947f6e.png/v1/fill/w_463,h_176,al_c,lg_1,q_85,enc_avif,quality_auto/a2f3b8_9f3074bd222048c1aea9f9d507947f6e.png"
                 alt="Logo de Jugos S.A."
                 class="logo-login" />

            <h1>Gestión de Formación</h1>
            <p class="subtitulo-login">Plataforma interna de capacitaciones - Jugos S.A.</p>

            <div class="login-card">
                <form id="account" method="post">

                    <h2>Inicio de sesión</h2>

                    <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-2" role="alert"></div>

                    <label asp-for="Input.UserName">Número de legajo</label>
                    <input asp-for="Input.UserName"
                           class="form-control"
                           autocomplete="username"
                           placeholder="Ej.: 1024" />
                    <span asp-validation-for="Input.UserName" class="text-danger"></span>

                    <label asp-for="Input.Password">Contraseña</label>
                    <input asp-for="Input.Password"
                           class="form-control"
                           autocomplete="current-password"
                           placeholder="********" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>

                    <div class="form-check mt-2 mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">
                            Recordarme
                        </label>
                    </div>

                    <button id="login-submit" type="submit" class="boton boton-principal ancho">
                        Entrar
                    </button>

                    <a asp-page="./SolicitarResetPassword" class="boton-link">
                        Restablecer contraseña
                    </a>

                </form>
            </div>
        </div>
    </section>

   

    

</body>
</html>
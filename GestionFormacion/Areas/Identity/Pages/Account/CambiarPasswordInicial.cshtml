@page
@model GestionFormacion.Areas.Identity.Pages.Account.CambiarPasswordInicialModel

@{
    ViewData["Title"] = "Cambiar contraseña";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <section class="card shadow p-4">

            <h2 class="text-center mb-4">
                Cambio obligatorio de contraseña
            </h2>

            <p class="text-center text-muted">
                Debe cambiar su contraseña antes de continuar.
            </p>

            <form method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.PasswordActual" class="form-control" />
                    <label asp-for="Input.PasswordActual"></label>
                    <span asp-validation-for="Input.PasswordActual" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.PasswordNueva" class="form-control" />
                    <label asp-for="Input.PasswordNueva"></label>
                    <span asp-validation-for="Input.PasswordNueva" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmarPassword" class="form-control" />
                    <label asp-for="Input.ConfirmarPassword"></label>
                    <span asp-validation-for="Input.ConfirmarPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="w-100 btn btn-primary">
                    Guardar nueva contraseña
                </button>

            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
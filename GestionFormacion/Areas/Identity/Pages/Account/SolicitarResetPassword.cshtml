@page
@model GestionFormacion.Areas.Identity.Pages.Account.SolicitarResetPasswordModel

@{
    ViewData["Title"] = "Solicitar reseteo de contraseña";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <section class="card shadow p-4">
            <h2 class="text-center mb-4">Solicitar reseteo</h2>

            <p class="text-center text-muted">
                Ingrese su legajo para solicitar al administrador el reseteo de su contraseña.
            </p>

            @if (!string.IsNullOrEmpty(Model.Mensaje))
            {
                <div class="alert alert-info">
                    @Model.Mensaje
                </div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Legajo" class="form-control" placeholder="Legajo" />
                    <label asp-for="Input.Legajo"></label>
                    <span asp-validation-for="Input.Legajo" class="text-danger"></span>
                </div>

                <button type="submit" class="w-100 btn btn-primary">
                    Solicitar reseteo
                </button>

                <div class="text-end mt-3">
                    <a asp-page="./Login" class="text-secondary">Volver al inicio de sesión</a>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
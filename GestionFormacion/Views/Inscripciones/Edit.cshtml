@model GestionFormacion.Models.Inscripcion

@{
    ViewData["Title"] = "Editar inscripción";
}

<h1>Editar inscripción</h1>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-light">
        <h4 class="mb-0">Modificar datos de la inscripción</h4>
    </div>

    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="FechaInscripcion" />

            <div class="mb-3">
                <label asp-for="EmpleadoId" class="form-label">Empleado</label>
                <select asp-for="EmpleadoId" class="form-select" asp-items="ViewBag.EmpleadoId"></select>
                <span asp-validation-for="EmpleadoId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CursoId" class="form-label">Curso</label>
                <select asp-for="CursoId" class="form-select" asp-items="ViewBag.CursoId"></select>
                <span asp-validation-for="CursoId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Fecha de solicitud</label>
                <input class="form-control"
                       value="@Model.FechaInscripcion.ToString("dd/MM/yyyy HH:mm")"
                       readonly />
            </div>

            <div class="mb-3">
                <label asp-for="Estado" class="form-label">Estado</label>
                <select asp-for="Estado" class="form-select">
                    <option value="Pendiente">Pendiente</option>
                    <option value="Aprobada">Aprobada</option>
                    <option value="Rechazada">Rechazada</option>
                </select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Guardar cambios
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Volver
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

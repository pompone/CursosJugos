@model GestionFormacion.Models.Empleado

@{
    ViewData["Title"] = "Detalle del empleado";
}

<h1>Detalle del empleado</h1>

<div>
    <h4>Datos del empleado</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Legajo</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Legajo)</dd>

        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Nombre)</dd>

        <dt class="col-sm-2">Apellido</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Apellido)</dd>

        <dt class="col-sm-2">DNI</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Dni)</dd>

        <dt class="col-sm-2">Sector</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Sector)</dd>

        <dt class="col-sm-2">Puesto</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Puesto)</dd>

        <dt class="col-sm-2">Activo</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Activo)</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
</div>
@model IEnumerable<GestionFormacion.Models.Curso>

@{
    ViewData["Title"] = "Solicitar capacitación";
}

<h1>Solicitar capacitación</h1>

<p class="text-muted">
    Seleccione el curso al que desea inscribirse.
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Curso</th>
            <th>Descripción</th>
            <th>Fecha de inicio</th>
            <th>Fecha de fin</th>
            <th>Horas</th>
            <th>Acción</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var curso in Model)
        {
            <tr>
                <td>@curso.NombreCurso</td>
                <td>@curso.Descripcion</td>
                <td>@curso.FechaInicio.ToShortDateString()</td>
                <td>@curso.FechaFin.ToShortDateString()</td>
                <td>@curso.Horas</td>
                <td>
                    <a class="btn btn-primary btn-sm"
                       asp-controller="Inscripciones"
                       asp-action="Create"
                       asp-route-cursoId="@curso.Id">
                        Solicitar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
    Volver al menú
</a>
@model GestionFormacion.Models.Inscripcion

@{
    ViewData["Title"] = "Solicitar capacitación";
}

<h1>Solicitar capacitación</h1>

<div class="card shadow-sm mt-4">
    <div class="card-body">
        <h4 class="card-title">Confirmación de solicitud</h4>

        <p>
            Está por solicitar la inscripción al curso seleccionado.
        </p>

        <p class="text-muted">
            La solicitud quedará registrada con estado <strong>Pendiente</strong>
            hasta que sea evaluada por el área correspondiente.
        </p>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="CursoId" />

            <button type="submit" class="btn btn-primary">
                Confirmar solicitud
            </button>

            <a asp-controller="Cursos" asp-action="Index" class="btn btn-secondary">
                Cancelar
            </a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

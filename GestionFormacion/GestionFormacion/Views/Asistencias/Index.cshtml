@model IEnumerable<GestionFormacion.Models.Asistencia>

@{
    ViewData["Title"] = "Asistencias";
}

<h1>Asistencias</h1>

@if (User.IsInRole("Admin"))
{
    <p class="text-muted">
        Desde esta pantalla se registran y consultan las asistencias de los empleados a los cursos.
    </p>

    <p>
        <a asp-action="Create" class="btn btn-primary">Registrar asistencia</a>
    </p>
}
else if (User.IsInRole("Empleado"))
{
    <p class="text-muted">
        Aquí puede consultar sus asistencias registradas.
    </p>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Empleado</th>
            <th>Curso</th>
            <th>Fecha</th>
            <th>Asistió</th>
            <th>Acción</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Empleado.Apellido, @item.Empleado.Nombre</td>
                <td>@item.Curso.NombreCurso</td>
                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    @if (item.Asistio)
                    {
                        <span class="badge bg-success">Sí</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">No</span>
                    }
                </td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                        Detalles
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            Editar
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                            Eliminar
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>